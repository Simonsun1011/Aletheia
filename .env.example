# Aletheia 环境变量示例（复制为 .env 后按需修改）
# 密钥只从环境变量读，永不入库

# 应用库路径（gitignore）
ALETHEIA_APP_DB=data/app.db

# 判断/随感 JSONL 目录（本地镜像，gitignore；异地备份走云镜像）
ALETHEIA_JOURNAL_DIR=data/journal

# 行情库（可再生，gitignore）
ALETHEIA_MARKET_DB=data/market/market_data.db

# 仓储后端：sqlite（默认）| firestore（完整第二 Store，目前仅为 stub，勿在生产切换）
ALETHEIA_STORE=sqlite

# 云端单向备份镜像（DESIGN v0.4）：off（默认）| firestore
# 本地写成功后 best-effort push；未配置凭证时 no-op，不影响本地可用性
ALETHEIA_CLOUD_MIRROR=off
# FIREBASE_PROJECT_ID=
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/serviceAccount.json
# （密钥文件永不入库；路径只放本机 .env）

# 前端 CORS（localhost 与 127.0.0.1 视为不同源，都要写上）
ALETHEIA_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# 日志（architecture §6.5）
ALETHEIA_LOG_LEVEL=INFO
ALETHEIA_LOG_DIR=logs

# AI（Slice 3+）— 模型名与密钥均来自环境，禁止写进代码
# OpenAI 兼容中转示例：
# OPENAI_API_KEY=sk-...
# OPENAI_API_BASE=https://your-host/v1
# MODEL_SUMMARY=openai/grok-4.5
MODEL_SUMMARY=openai/grok-4.5
# 操作台 AI 独立扫描（须带联网搜索；未配置则区B禁用，不降级编造）
# MODEL_SEARCH=openai/grok-4.5
# OPENAI_API_KEY=
# OPENAI_API_BASE=
# ANTHROPIC_API_KEY=

# LLM 月度预算（美元，可选；超限时 digest 等批处理跳过 LLM，交互式调用仍放行并附 warning）
# MONTHLY_LLM_BUDGET_USD=10

# Slice 3c：初筛调参期把丢弃项写入「查看漏杀」（默认关；稳定后保持关）
# FEED_PRESCREEN_AUDIT=1

# 前端（可选；端口冲突时改后端端口并同步这里）
# NEXT_PUBLIC_API_BASE=http://127.0.0.1:8000/api

# Slice 7：Obsidian 术语笔记导出目录（绝对路径；含空格时整段作为单路径，勿拆分）
# 未配置则「加入知识笔记」按钮禁用
# OBSIDIAN_EXPORT_DIR=/Users/simonsun/Documents/Obsidian Vault/Personal Knowledge/Aletheia
