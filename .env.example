# Aletheia 环境变量示例（复制为 .env 后按需修改）
# 密钥只从环境变量读，永不入库

# 应用库路径（gitignore）
ALETHEIA_APP_DB=data/app.db

# 判断/随感 JSONL 目录（随 git 提交）
ALETHEIA_JOURNAL_DIR=data/journal

# 前端 CORS
ALETHEIA_CORS_ORIGINS=http://localhost:3000

# 日志（architecture §6.5）：级别 DEBUG|INFO|WARNING|ERROR；目录默认 logs/
ALETHEIA_LOG_LEVEL=INFO
ALETHEIA_LOG_DIR=logs

# 前端（可选；端口冲突时改后端端口并同步这里）
# NEXT_PUBLIC_API_BASE=http://127.0.0.1:8001/api
